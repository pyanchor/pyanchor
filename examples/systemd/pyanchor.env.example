# /etc/pyanchor.env — EnvironmentFile for pyanchor.service.
#
# After copying:
#   sudo chmod 600 /etc/pyanchor.env   # contains secrets — root-only
#   sudo chown root:pyanchor /etc/pyanchor.env  # readable by service user
#
# systemd parses this as KEY=VALUE pairs (no quoting needed for simple
# values, no `export` keyword). Comments start with `#`.

# ─── required ───────────────────────────────────────────────────────

# Random 32-byte hex secret. The host app's bootstrap script tag's
# data-pyanchor-token MUST match this value.
PYANCHOR_TOKEN=replace-with-openssl-rand-hex-32

# The deployed app dir (where rsync writes after a successful edit).
PYANCHOR_APP_DIR=/srv/myapp

# Working tree the agent edits. For PR mode, this should be a git
# clone of your app repo with PYANCHOR_GIT_BASE_BRANCH checked out.
PYANCHOR_WORKSPACE_DIR=/var/lib/pyanchor/workspace

# Script that restarts your app process after a successful edit
# (apply mode only — PR mode never invokes this).
PYANCHOR_RESTART_SCRIPT=/opt/pyanchor/restart.sh

# Liveness URL pyanchor probes after restart to confirm the app
# came back up.
PYANCHOR_HEALTHCHECK_URL=http://127.0.0.1:3000/

# CSRF allowlist. Comma-separated list of trusted origins.
PYANCHOR_ALLOWED_ORIGINS=https://app.example.com

# ─── agent (one of openclaw / claude-code / codex / aider / gemini) ─

PYANCHOR_AGENT=openclaw
# PYANCHOR_AGENT_MODEL=openai-codex/gpt-5.4   # optional override

# ─── production gating (defense in depth, recommended) ─────────────

PYANCHOR_REQUIRE_GATE_COOKIE=true
PYANCHOR_GATE_COOKIE_NAME=pyanchor_dev

# ─── audit log (highly recommended for production) ─────────────────

PYANCHOR_AUDIT_LOG=true
PYANCHOR_AUDIT_LOG_FILE=/var/lib/pyanchor/state/audit.jsonl

# ─── output mode ───────────────────────────────────────────────────

# apply (default) | pr | dryrun. PR mode requires gh + git on PATH
# and a workspace that is a git working tree.
PYANCHOR_OUTPUT_MODE=apply
# PYANCHOR_GIT_BASE_BRANCH=main          # for pr mode

# ─── actor signing (v0.27.0+, optional but recommended) ────────────

# When set, X-Pyanchor-Actor must be `<actor>.<hex-sha256-hmac>`.
# Mismatched values are dropped from the audit trail (the edit still
# proceeds — the host's other auth gates already let the request
# through). Generate with: openssl rand -hex 32
# PYANCHOR_ACTOR_SIGNING_SECRET=replace-with-openssl-rand-hex-32

# ─── webhooks (optional) ───────────────────────────────────────────

# PYANCHOR_WEBHOOK_EDIT_REQUESTED_URL=https://hooks.slack.com/services/...
# PYANCHOR_WEBHOOK_EDIT_APPLIED_URL=https://hooks.slack.com/services/...
# PYANCHOR_WEBHOOK_PR_OPENED_URL=https://hooks.slack.com/services/...
