{
  "name": "pyanchor",
  "version": "0.31.3",
  "description": "Agent-agnostic AI live-edit sidecar for Next.js. Anchor edits straight into your running app.",
  "license": "MIT",
  "author": "PYAN <ikellllllll@users.noreply.github.com>",
  "homepage": "https://github.com/pyanchor/pyanchor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyanchor/pyanchor.git"
  },
  "bugs": {
    "url": "https://github.com/pyanchor/pyanchor/issues"
  },
  "keywords": [
    "pyanchor",
    "openclaw",
    "claude-code",
    "codex",
    "aider",
    "ai",
    "agent",
    "sidecar",
    "nextjs",
    "live-edit",
    "devtools",
    "overlay"
  ],
  "type": "module",
  "main": "dist/server.cjs",
  "bin": {
    "pyanchor": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/server.cjs",
    "dev": "node build.mjs && node dist/server.cjs",
    "typecheck": "tsc --noEmit",
    "test": "node build.mjs && vitest run",
    "test:coverage": "node build.mjs && vitest run --coverage",
    "test:e2e": "node build.mjs && playwright test",
    "test:e2e:ui": "node build.mjs && playwright test --ui",
    "test:all": "node build.mjs && vitest run && playwright test"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@playwright/test": "^1.59.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.8.9",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.25.0": ">=0.25.0"
    },
    "_overrides_notes": {
      "esbuild": "GHSA-67mh-4wv8-2f99 — dev-server fetch hijack in vitest > vite > esbuild transitive. Patch: 0.25+. Forces transitive bump without touching vitest/vite versions.",
      "vite": "GHSA-4w7w-66w2-5vf9 — path traversal in vite optimized-deps .map handling. Patched in 6.4.2, but vitest@2.x peers vite@^5 — overriding vite to 6.x breaks the testsuite. Holding until vitest@3.x upgrade lands as a separate ship. Risk in our case: dev-server only, never in shipped runtime; vite reaches us via vitest dev dep, not production."
    }
  }
}
