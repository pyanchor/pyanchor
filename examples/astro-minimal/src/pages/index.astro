---
import Base from "../layouts/Base.astro";
---

<Base title="pyanchor — astro example">
  <main style="text-align: center; padding: 2rem; max-width: 560px;">
    <h1 style="font-size: 2.4rem; margin: 0;">Hello, pyanchor (Astro)</h1>
    <p style="opacity: 0.75; line-height: 1.6; margin-top: 16px;">
      Astro isn't a built-in framework profile yet — pyanchor falls back to
      the nextjs profile and prints a warning. This example shows the explicit
      <code>PYANCHOR_INSTALL_COMMAND</code> / <code>PYANCHOR_BUILD_COMMAND</code>
      override path that lets <em>any</em> framework run.
    </p>
    <p style="opacity: 0.6; font-size: 0.9rem; margin-top: 24px;">
      Click the floating button (bottom-right) to ask the agent to change this page.
    </p>
  </main>
</Base>
