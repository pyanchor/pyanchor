# Copy to .env.local before running `next dev`.
#
# These are the public flags the Next.js side reads. The pyanchor sidecar
# itself takes a separate, larger env (see ../../.env.example).

# Toggle the in-page overlay. Leave empty / unset to disable.
NEXT_PUBLIC_PYANCHOR_DEVTOOLS_ENABLED=true

# Bearer token the overlay forwards on every API call.
# MUST match the PYANCHOR_TOKEN you start the sidecar with.
NEXT_PUBLIC_PYANCHOR_TOKEN=replace-me-with-32-random-bytes
