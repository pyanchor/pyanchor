# ──────────────────────────────────────────────────────────────────────
# pyanchor environment variables
#
# Copy to `.env` (or load via your process manager) before running.
# Required variables are marked REQUIRED. The sidecar refuses to start
# if any required variable is missing.
# ──────────────────────────────────────────────────────────────────────


# ─── REQUIRED: target Next.js app integration ────────────────────────

# Absolute path to your running Next.js app (where pyanchor will apply edits).
PYANCHOR_APP_DIR=/path/to/your/nextjs-app

# Executable that restarts your Next.js frontend after a successful edit.
# Examples: a script that wraps `pm2 restart`, `systemctl restart`,
# `docker compose restart`, etc. Pyanchor invokes it with no arguments.
PYANCHOR_RESTART_SCRIPT=/path/to/restart-frontend.sh

# URL that should return 2xx once the frontend is back up. Used for
# self-healing after a restart.
PYANCHOR_HEALTHCHECK_URL=http://127.0.0.1:3000/

# ─── REQUIRED: agent workspace ───────────────────────────────────────

# Scratch directory the agent writes into before changes are synced
# back to PYANCHOR_APP_DIR. Should be writable by the agent process.
PYANCHOR_WORKSPACE_DIR=/path/to/pyanchor-workspace


# ─── REQUIRED: bearer token for the runtime + admin API ──────────────

# All /api/* routes and the admin index require this token via either
# `Authorization: Bearer <token>` or `?token=<token>`.
# Generate with: openssl rand -hex 32
PYANCHOR_TOKEN=replace-me-with-32-random-bytes


# ─── Agent (OpenClaw is the v0.1.0 default) ──────────────────────────

# Path to the OpenClaw CLI binary.
# Default: openclaw (resolved via PATH)
# PYANCHOR_OPENCLAW_BIN=openclaw

# Unix user to invoke OpenClaw as. Defaults to the user running pyanchor.
# Set this if your agent runs under a different account (sudo required).
# PYANCHOR_OPENCLAW_USER=openclaw

# OpenClaw agent id pyanchor manages. Default: "pyanchor"
# PYANCHOR_AGENT_ID=pyanchor

# Default model and reasoning level passed to OpenClaw.
# PYANCHOR_AGENT_MODEL=openai-codex/gpt-5.4
# PYANCHOR_AGENT_THINKING=medium


# ─── Cross-user / file ownership ─────────────────────────────────────

# Owner string for `chown` after the agent writes files back.
# Default: "<currentUser>:<currentUser>"
# PYANCHOR_APP_DIR_OWNER=studio:studio

# pm2 process name (only used by some restart scripts; informational).
# PYANCHOR_FRONTEND_PM2_NAME=


# ─── Timeouts (seconds / milliseconds) ───────────────────────────────

# PYANCHOR_AGENT_TIMEOUT_S=900
# PYANCHOR_INSTALL_TIMEOUT_MS=600000
# PYANCHOR_BUILD_TIMEOUT_MS=900000


# ─── Server ──────────────────────────────────────────────────────────

# PYANCHOR_PORT=3010
# PYANCHOR_HOST=127.0.0.1
# PYANCHOR_RUNTIME_BASE_PATH=/_pyanchor
# PYANCHOR_RUNTIME_ALIAS_PATH=/runtime


# ─── Paths (auto-derived; override only if needed) ───────────────────

# Directory for state.json and the lock file.
# Default: $HOME/.pyanchor
# PYANCHOR_STATE_DIR=

# Path to a peer process's state file. If set, pyanchor will avoid
# starting a job while the peer process is busy. Useful when another
# tool shares the same app directory.
# PYANCHOR_PEER_STATE_FILE=

# Override only if running pyanchor outside the installed package.
# PYANCHOR_SERVICE_ROOT=
# PYANCHOR_WORKER_SCRIPT=
# PYANCHOR_STATIC_DIR=
# PYANCHOR_APP_DIR_LOCK=


# ─── Worker IPC (set automatically by the sidecar; do not set manually) ─
# PYANCHOR_JOB_ID
# PYANCHOR_JOB_PROMPT
# PYANCHOR_JOB_TARGET_PATH
# PYANCHOR_JOB_MODE
# PYANCHOR_STATE_FILE_PATH
# PYANCHOR_RESTART_AFTER_EDIT
